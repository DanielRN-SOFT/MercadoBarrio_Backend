generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

model ProductCategory {
  id       Int                   @id @default(autoincrement())
  name     String                @unique @db.VarChar(100)
  status   ProductCategoryStatus
  products Product[]

  @@map("product_categories")
}

model StoreCategory {
  id     Int                 @id @default(autoincrement())
  name   String              @unique @db.VarChar(45)
  status StoreCategoryStatus
  stores Store[]

  @@map("store_categories")
}

model MovementDetail {
  id         Int      @id @default(autoincrement())
  productId  Int
  movementId Int
  quantity   Int
  unitCost   Decimal  @db.Decimal(10, 2)
  movement   Movement @relation(fields: [movementId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  product    Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([movementId])
  @@index([productId])
  @@map("movement_details")
}

model SaleDetail {
  id        Int     @id @default(autoincrement())
  saleId    Int
  productId Int
  quantity  Decimal @db.Decimal(10, 4)
  unitPrice Decimal @db.Decimal(10, 4)
  subtotal  Decimal @db.Decimal(10, 2)
  product   Product @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([productId])
  @@index([saleId])
  @@map("sale_details")
}

model AttendanceSchedule {
  id        Int            @id @default(autoincrement())
  weekDay   WeekDay
  startTime DateTime       @db.Time(0)
  endTime   DateTime       @db.Time(0)
  status    ScheduleStatus
  storeId   Int
  store     Store          @relation(fields: [storeId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([storeId])
  @@map("attendance_schedules")
}

model AuditLog {
  id              Int      @id @default(autoincrement())
  timestampUtc    DateTime @default(now()) @db.Timestamp(0)
  eventActionType String   @db.VarChar(45)
  userId          Int
  clientIp        String   @db.VarChar(45)
  resourceType    String   @db.VarChar(45)
  resourceId      Int
  previousValue   String?  @db.LongText
  newValue        String?  @db.LongText
  description     String   @db.VarChar(45)
  status          AuditLogStatus

  @@map("audit_logs")
}

model Movement {
  id               Int              @id @default(autoincrement())
  date             DateTime         @db.DateTime(0)
  status           MovementStatus
  type             MovementType
  reason           String?          @db.Text
  supplierId       Int?
  userId           Int
  storeId          Int
  cancellationDate DateTime?        @db.DateTime(0)
  details          MovementDetail[]
  supplier         Supplier?        @relation(fields: [supplierId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  store            Store            @relation(fields: [storeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user             User             @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([supplierId])
  @@index([storeId])
  @@index([userId])
  @@map("movements")
}

model Product {
  id                Int              @id @default(autoincrement())
  name              String           @db.VarChar(100)
  price             Decimal          @db.Decimal(10, 2)
  description       String?          @db.Text
  referenceCode     String?          @db.VarChar(45)
  lowStockThreshold Int              @default(5)
  photo             String?          @db.VarChar(255)
  currentStock      Int
  status            ProductStatus
  productCategoryId Int
  unitOfMeasureId   Int
  storeId           Int
  deactivationDate  DateTime?        @db.DateTime(0)
  movementDetails   MovementDetail[]
  saleDetails       SaleDetail[]
  productCategory   ProductCategory  @relation(fields: [productCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  store             Store            @relation(fields: [storeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  unitOfMeasure     UnitOfMeasure    @relation(fields: [unitOfMeasureId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([productCategoryId])
  @@index([storeId])
  @@index([unitOfMeasureId])
  @@map("products")
}

model Supplier {
  id        Int            @id @default(autoincrement())
  name      String         @db.VarChar(45)
  phone     String         @db.VarChar(45)
  status    SupplierStatus
  movements Movement[]

  @@map("suppliers")
}

model Role {
  id    Int        @id @default(autoincrement())
  name  String     @unique @db.VarChar(100)
  status RoleStatus
  users User[]

  @@map("roles")
}

model Store {
  id              Int                  @id @default(autoincrement())
  name            String               @db.VarChar(45)
  address         String               @db.VarChar(100)
  longitude       Decimal              @db.Decimal(10, 8)
  latitude        Decimal              @db.Decimal(10, 8)
  description     String?              @db.Text
  logo            String?              @db.VarChar(200)
  phone           String?              @db.VarChar(45)
  status          StoreStatus
  userId          Int
  storeCategoryId Int
  onboardingStep  String               @db.VarChar(45)
  schedules       AttendanceSchedule[]
  movements       Movement[]
  products        Product[]
  storeCategory   StoreCategory        @relation(fields: [storeCategoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user            User                 @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales           Sale[]

  @@index([storeCategoryId])
  @@index([userId])
  @@map("stores")
}

model UnitOfMeasure {
  id       Int               @id @default(autoincrement())
  name     String            @unique @db.VarChar(45)
  status   UnitOfMeasureStatus
  products Product[]

  @@map("units_of_measure")
}

model User {
  id        Int        @id @default(autoincrement())
  name      String     @db.VarChar(45)
  email     String     @unique @db.VarChar(150)
  password  String     @db.VarChar(250)
  phone     String     @db.VarChar(45)
  status    UserStatus
  roleId    Int
  movements Movement[]
  stores    Store[]
  role      Role       @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sales     Sale[]

  @@index([roleId])
  @@map("users")
}

model Sale {
  id                 Int        @id @default(autoincrement())
  date               DateTime   @db.DateTime(0)
  total              Decimal    @db.Decimal(10, 2)
  status             SaleStatus
  userId             Int
  storeId            Int
  cancellationReason String?    @db.Text
  cancellationDate   DateTime?  @db.DateTime(0)
  details            SaleDetail[]
  store              Store      @relation(fields: [storeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user               User       @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([storeId])
  @@index([userId])
  @@map("sales")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum WeekDay {
  Monday    @map("Lunes")
  Tuesday   @map("Martes")
  Wednesday @map("Miércoles")
  Thursday  @map("Jueves")
  Friday    @map("Viernes")
  Saturday  @map("Sábado")
  Sunday    @map("Domingo")

  @@map("week_day")
}

enum ProductCategoryStatus {
  Active   @map("Activo")
  Inactive @map("Inactivo")

  @@map("product_category_status")
}

enum StoreCategoryStatus {
  Active   @map("Activo")
  Inactive @map("Inactivo")

  @@map("store_category_status")
}

enum MovementStatus {
  Active    @map("Activo")
  Cancelled @map("Cancelada")

  @@map("movement_status")
}

enum MovementType {
  Entry       @map("Entrada")
  Exit        @map("Salida")
  AdjustEntry @map("Ajuste-Entrada")
  AdjustExit  @map("Ajuste-Salida")

  @@map("movement_type")
}

enum SupplierStatus {
  Active   @map("Activo")
  Inactive @map("Inactivo")

  @@map("supplier_status")
}

enum SaleStatus {
  Completed @map("Completada")
  Cancelled @map("Cancelada")

  @@map("sale_status")
}

enum ScheduleStatus {
  Active   @map("Activo")
  Inactive @map("Inactivo")

  @@map("schedule_status")
}

enum UserStatus {
  Active   @map("Activo")
  Inactive @map("Inactivo")

  @@map("user_status")
}

enum ProductStatus {
  Active   @map("Activo")
  Inactive @map("Inactivo")

  @@map("product_status")
}

enum UnitOfMeasureStatus {
  Active   @map("Activo")
  Inactive @map("Inactivo")

  @@map("unit_of_measure_status")
}

enum StoreStatus {
  Active     @map("Activo")
  Inactive   @map("Inactivo")
  Pending    @map("Pendiente")
  Incomplete @map("Incompleto")
  Rejected   @map("Rechazado")

  @@map("store_status")
}

enum RoleStatus {
  Active   @map("Activo")
  Inactive @map("Inactivo")

  @@map("role_status")
}

enum AuditLogStatus {
  Active   @map("Activo")
  Inactive @map("Inactivo")

  @@map("audit_log_status")
}
